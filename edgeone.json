{
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "nodeVersion": "22.11.0",
  "headers": [
    {
      "source": "/*",
      "headers": [
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/css/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/js/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/icon/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/site/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/runtime/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    },
    {
      "source": "/favicon.svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    },
    {
      "source": "/site.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=1800, must-revalidate"
        }
      ]
    },
    {
      "source": "/:lang/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=1800, must-revalidate"
        }
      ]
    }
  ],
  "caches": [
    {
      "source": "/css/*",
      "cacheTtl": 31536000
    },
    {
      "source": "/js/*",
      "cacheTtl": 31536000
    },
    {
      "source": "/icon/*",
      "cacheTtl": 31536000
    },
    {
      "source": "/site/*",
      "cacheTtl": 31536000
    },
    {
      "source": "/runtime/*",
      "cacheTtl": 31536000
    },
    {
      "source": "/favicon.ico",
      "cacheTtl": 86400
    },
    {
      "source": "/favicon.svg",
      "cacheTtl": 86400
    },
    {
      "source": "/site.webmanifest",
      "cacheTtl": 3600
    },
    {
      "source": "/robots.txt",
      "cacheTtl": 3600
    },
    {
      "source": "/sw.js",
      "cacheTtl": 0
    },
    {
      "source": "/index.xml",
      "cacheTtl": 300
    },
    {
      "source": "/sitemap.xml",
      "cacheTtl": 1800
    },
    {
      "source": "/:lang/sitemap.xml",
      "cacheTtl": 1800
    }
  ]
}
